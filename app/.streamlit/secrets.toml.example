# Copie para .streamlit/secrets.toml e preencha. NÃO comite o secrets.toml real.
# Alternativamente, defina como variáveis de ambiente de mesmo nome.

# URL do microsserviço Scanner (FastAPI). Padrão: http://localhost:8000
SCANNER_URL = "http://localhost:8000"

# Chave da API do Gemini. Sem ela, o app usa classificação heurística (sem IA).
GEMINI_API_KEY = ""

# Modelo Gemini (opcional). Padrão: gemini-2.5-flash
GEMINI_MODEL = "gemini-2.5-flash"
