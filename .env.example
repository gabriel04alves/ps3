# ==========================================================================
# Scanner SSL/TLS — variáveis de ambiente
# --------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha os valores:
#     cp .env.example .env
#
# O Docker Compose lê o `.env` da raiz automaticamente. No compose, são
# interpolados: GEMINI_API_KEY, GEMINI_MODEL, SCAN_TIMEOUT_S e TRAEFIK_NETWORK
# (SCANNER_URL e API_PREFIX já são fixados internamente pelo compose). As demais
# variáveis valem para a execução manual (sem Docker).
#
# O `.env` real está no .gitignore — NÃO comite segredos.
# ==========================================================================

# --- IA · Gemini (classificação de risco a jusante) -----------------------
# Chave da API do Google Gemini. Obtenha em: https://aistudio.google.com/apikey
# Se ficar vazia, o app continua funcional usando uma heurística determinística
# (sem IA) — apenas a análise de risco fica menos rica.
GEMINI_API_KEY=

# Modelo Gemini utilizado na análise. Padrão: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# --- Scanner (microsserviço FastAPI) --------------------------------------
# URL em que o dashboard encontra o microsserviço Scanner.
# - Docker Compose (rede interna): http://scanner:8000
# - Execução manual (local):       http://localhost:8000
SCANNER_URL=http://localhost:8000

# Timeout (segundos) da varredura. Ela é remota, real e síncrona (~1–3 min),
# podendo ultrapassar em alvos com muitos protocolos legados. Deixe folgado.
SCAN_TIMEOUT_S=300

# Timeout (segundos) do health check do scanner exibido na sidebar.
HEALTH_TIMEOUT_S=5

# --- Scanner · proxy reverso (opcional) -----------------------------------
# Prefixo de rota para servir a API atrás de um proxy (ex.: /api).
# Em branco = sem prefixo (docs em /docs, scan em /scan).
API_PREFIX=

# Root path do FastAPI quando montado sob um subcaminho (uso avançado).
FASTAPI_ROOT_PATH=

# --- Infraestrutura · Docker Compose / Traefik ----------------------------
# Nome da rede externa do proxy reverso (Traefik/Dokploy) usada pelo compose.
TRAEFIK_NETWORK=dokploy-network
